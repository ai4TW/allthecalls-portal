TRILLET_API_KEY=
TRILLET_WORKSPACE_ID=
SESSION_SECRET=

# JSON array of portal users. Each object maps a login to a Trillet agent.
# [{"email":"...","password":"...","agentId":"...","flowId":"...","name":"..."}]
USERS_JSON=[]

# Per-tenant Supabase service-role keys. The tenant registry in lib/tenants.ts
# names the env var for each client (e.g. WBHC_SUPABASE_SERVICE_ROLE_KEY).
# Without these, /<tenant> pages fall back to sample data.
WBHC_SUPABASE_SERVICE_ROLE_KEY=

# Trillet agent ID for WBHC's Jaz agent. Used by the /api/webhooks/trillet
# handler to route inbound call events to the WBHC tenant. Get from Trillet
# dashboard → Agents → Jaz → ID.
WBHC_TRILLET_AGENT_ID=

# Shared secret for the Trillet webhook URL. Set this, then add it to the
# webhook URL in Trillet as ?secret=<value>. Rotate by changing this value.
TRILLET_WEBHOOK_SECRET=
